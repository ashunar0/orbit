{
  "name": "orbit-router",
  "version": "0.1.14",
  "description": "Directory-based, type-safe router for Vite+ and React.",
  "license": "MIT",
  "author": "ashunar0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashunar0/orbit-router",
    "directory": "packages/orbit-router"
  },
  "keywords": [
    "router",
    "react",
    "vite",
    "file-based-routing",
    "type-safe"
  ],
  "files": [
    "dist",
    "src/client.d.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./src/client.d.ts"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@testing-library/react": "catalog:",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "happy-dom": "catalog:",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "vite": ">=6.0.0"
  },
  "dependencies": {}
}
